---
import FormatDemoLayout from '../../../components/FormatDemoLayout.astro';
---

<FormatDemoLayout
    apiHref="/facilis/reference/formats/domestic-phone-number/"
    title="domesticPhoneNumber() Demo"
>
    <article class="demo-card">
        <h2>Default formatting</h2>
        <p>The phone number format grows naturally from <code>(4</code> to <code>(414) 555-1212</code> as digits are entered.</p>
        <label class="demo-label" for="phone-basic">Type a phone number</label>
        <input class="demo-input" id="phone-basic" data-demo-phone-basic type="text" placeholder="Try 4145551212" />
        <p class="demo-note">Try <code>4145551212</code> to see the default phone formatting.</p>
    </article>

    <article class="demo-card">
        <h2>Paste messy input</h2>
        <p>Non-digit characters are ignored, which makes pasted phone strings safe to normalize.</p>
        <label class="demo-label" for="phone-paste">Paste punctuation-heavy text</label>
        <input class="demo-input" id="phone-paste" data-demo-phone-paste type="text" placeholder="Try (414) 555-1212 ext 99" />
        <p class="demo-note">Try pasting: <code>(414) 555-1212 ext 99</code>. Only the first ten digits should remain in the formatted result.</p>
    </article>

    <script>
        import { mountDomesticPhoneNumberDemo } from '../../../demo/mountFormatDemos.ts';

        mountDomesticPhoneNumberDemo();
    </script>
</FormatDemoLayout>
