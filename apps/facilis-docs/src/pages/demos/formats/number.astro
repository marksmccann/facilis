---
import FormatDemoLayout from '../../../components/FormatDemoLayout.astro';
---

<FormatDemoLayout
    apiHref="/facilis/reference/formats/number/"
    title="number() Demo"
>
    <article class="demo-card">
        <h2>Default formatting</h2>
        <p>The default number format keeps a plain integer string without grouping or a fractional portion.</p>
        <label class="demo-label" for="number-default">Type a number</label>
        <input class="demo-input" id="number-default" data-demo-number-default type="text" placeholder="Try 12345" />
        <p class="demo-note">Try <code>12345</code> to see the default number formatting.</p>
    </article>

    <article class="demo-card">
        <h2>Blur padding</h2>
        <p>Pad the fractional portion on blur when the resting value should settle to a fixed decimal length.</p>
        <label class="demo-label" for="number-padded">Blur-padded number</label>
        <input class="demo-input" id="number-padded" data-demo-number-padded type="text" placeholder="Try 12345 and blur" />
        <p class="demo-note">This scenario uses <code>decimalPlaces: 0</code> and <code>padDecimalPlaces: 2</code> so <code>12345</code> becomes <code>12345.00</code> on blur.</p>
    </article>

    <article class="demo-card">
        <h2>Thousands separators</h2>
        <p>Enable grouped thousands and preserve up to two decimal places for a more display-oriented numeric value.</p>
        <label class="demo-label" for="number-grouped">Grouped number</label>
        <input class="demo-input" id="number-grouped" data-demo-number-grouped type="text" placeholder="Try 12345.67" />
        <p class="demo-note">This scenario uses the thousands separator: <code>,</code> and the decimal separator: <code>.</code>.</p>
    </article>

    <article class="demo-card">
        <h2>Custom separators</h2>
        <p>Swap both separators when the surrounding UI expects grouped thousands with <code>.</code> and decimals with <code>,</code>.</p>
        <label class="demo-label" for="number-separators">Localized separators</label>
        <input class="demo-input" id="number-separators" data-demo-number-separators type="text" placeholder="Try 12345,67" />
        <p class="demo-note">This scenario uses the thousands separator: <code>.</code> and the decimal separator: <code>,</code>.</p>
    </article>

    <article class="demo-card">
        <h2>No thousands separator</h2>
        <p>Leave the digits ungrouped while still preserving a fractional portion when grouping would add unnecessary visual noise.</p>
        <label class="demo-label" for="number-plain-groups">Ungrouped decimal number</label>
        <input class="demo-input" id="number-plain-groups" data-demo-number-plain-groups type="text" placeholder="Try 12345.67" />
        <p class="demo-note">This scenario sets the thousands separator to an empty string.</p>
    </article>

    <article class="demo-card">
        <h2>Negative values</h2>
        <p>Preserve a leading minus sign when the format should support signed numeric input.</p>
        <label class="demo-label" for="number-negative">Signed number</label>
        <input class="demo-input" id="number-negative" data-demo-number-negative type="text" placeholder="Try -12345.67" />
        <p class="demo-note">This scenario enables negative values and uses grouped thousands with up to two decimal places.</p>
    </article>

    <article class="demo-card">
        <h2>Leading zero insertion</h2>
        <p>Keep shorthand decimals easy to edit while typing, then settle them to a zero-prefixed value on blur.</p>
        <label class="demo-label" for="number-leading-zero">Shorthand decimal</label>
        <input class="demo-input" id="number-leading-zero" data-demo-number-leading-zero type="text" placeholder="Try .5" />
        <p class="demo-note">This scenario uses <code>decimalPlaces: 2</code> and <code>insertLeadingZero: true</code>, so <code>.5</code> stays editable while typing and becomes <code>0.5</code> after blur.</p>
    </article>

    <article class="demo-card">
        <h2>Trim leading zeros</h2>
        <p>Collapse unnecessary integer padding while preserving the one zero that still carries numeric meaning.</p>
        <label class="demo-label" for="number-trim-zeros">Trimmed integer</label>
        <input class="demo-input" id="number-trim-zeros" data-demo-number-trim-zeros type="text" placeholder="Try 00012" />
        <p class="demo-note">This scenario uses <code>trimLeadingZeros: true</code>, so values like <code>00012</code> become <code>12</code> while a single <code>0</code> remains intact.</p>
    </article>

    <article class="demo-card">
        <h2>Maximum clamp</h2>
        <p>Clamp the value to a maximum as soon as typing resolves to a complete number above the allowed range.</p>
        <label class="demo-label" for="number-max">Maximum 100</label>
        <input class="demo-input" id="number-max" data-demo-number-max type="text" placeholder="Try 101" />
        <p class="demo-note">This scenario uses <code>max: 100</code>, so values like <code>101</code> or <code>999</code> become <code>100</code> while typing.</p>
    </article>

    <article class="demo-card">
        <h2>Minimum clamp</h2>
        <p>Clamp signed input back to a minimum when the number resolves below the allowed range.</p>
        <label class="demo-label" for="number-min">Minimum 0</label>
        <input class="demo-input" id="number-min" data-demo-number-min type="text" placeholder="Try -5" />
        <p class="demo-note">This scenario uses <code>allowNegative: true</code> and <code>min: 0</code>, so values like <code>-5</code> become <code>0</code>.</p>
    </article>

    <article class="demo-card">
        <h2>Decimal clamp</h2>
        <p>Clamp decimal input to a maximum while still preserving in-progress values like a trailing decimal separator.</p>
        <label class="demo-label" for="number-decimal-max">Maximum 10 with decimals</label>
        <input class="demo-input" id="number-decimal-max" data-demo-number-decimal-max type="text" placeholder="Try 10.5" />
        <p class="demo-note">This scenario uses <code>decimalPlaces: 2</code> and <code>max: 10</code>, so <code>10.5</code> becomes <code>10</code> while <code>10.</code> stays in progress.</p>
    </article>

    <script>
        import { mountNumberDemo } from '../../../demo/mountFormatDemos.ts';

        mountNumberDemo();
    </script>
</FormatDemoLayout>
